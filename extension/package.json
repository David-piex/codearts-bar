{
  "name": "codearts-bar-status",
  "displayName": "\u7801\u9053\u72b6\u6001\u680f",
  "description": "\u5728 VS Code / CodeArts Agent \u72b6\u6001\u680f\u663e\u793a\u672c\u5730\u7801\u9053 token \u4f7f\u7528\u60c5\u51b5\u3002",
  "version": "1.16.25",
  "publisher": "local-codearts",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeartsBar.refresh",
    "onCommand:codeartsBar.showDetails"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeartsBar.refresh",
        "title": "\u7801\u9053\u72b6\u6001\u680f\uff1a\u5237\u65b0\u4f7f\u7528\u60c5\u51b5"
      },
      {
        "command": "codeartsBar.showDetails",
        "title": "\u7801\u9053\u72b6\u6001\u680f\uff1a\u663e\u793a\u8be6\u60c5"
      },
      {
        "command": "codeartsBar.openDataFolder",
        "title": "\u7801\u9053\u72b6\u6001\u680f\uff1a\u6253\u5f00\u6570\u636e\u76ee\u5f55"
      }
    ],
    "configuration": {
      "title": "\u7801\u9053\u72b6\u6001\u680f",
      "properties": {
        "codeartsBar.dbPath": {
          "type": "string",
          "default": "",
          "description": "CodeArts opencode.db \u8def\u5f84\u3002\u4e3a\u7a7a\u65f6\u4f7f\u7528 ~/.codeartsdoer/codearts-data/opencode.db\u3002"
        },
        "codeartsBar.dailyLimit": {
          "type": "number",
          "default": 200000,
          "description": "\u72b6\u6001\u680f\u767e\u5206\u6bd4\u4f7f\u7528\u7684\u6bcf\u65e5 token \u663e\u793a\u8f6f\u4e0a\u9650\u3002"
        },
        "codeartsBar.windowHours": {
          "type": "number",
          "default": 24,
          "description": "\u6eda\u52a8\u7a97\u53e3\u7edf\u8ba1\u5c0f\u65f6\u6570\u3002"
        },
        "codeartsBar.refreshMs": {
          "type": "number",
          "default": 60000,
          "description": "\u81ea\u52a8\u5237\u65b0\u95f4\u9694\uff0c\u6beb\u79d2\u3002"
        }
      }
    }
  },
  "files": [
    "extension.js",
    "codeartsData.js",
    "node_modules/sql.js/dist/sql-wasm.js",
    "node_modules/sql.js/dist/sql-wasm.wasm",
    "README.md",
    "package.json",
    "LICENSE",
    "officialStats.js",
    "authStatus.js",
    "settings.js",
    "quota.js",
    "providers/index.js",
    "health.js",
    "providers/codeartsLocal.js",
    "providers/codeartsOfficial.js",
    "providers/codeartsDesktop.js",
    "core/aggregator.js",
    "core/format.js",
    "core/cacheMetrics.js",
    "providers/codearts/aggregation-sql.js",
    "providers/codearts/aggregation.js",
    "providers/codearts/collect.js",
    "providers/codearts/logs.js",
    "providers/codearts/pagination.js",
    "providers/codearts/session-actions.js",
    "providers/codearts/sources.js",
    "providers/codearts/sqlite.js",
    "providers/codearts/aggregate-cache.js",
    "providers/codearts/aggregation-engine.js",
    "providers/codearts/aggregation-runtime.js",
    "providers/codearts/aggregation-sql-expressions.js",
    "providers/codearts/aggregation-workers.js",
    "providers/codearts/diagnostics.js",
    "providers/codearts/rollup-cache.js",
    "providers/codearts/sqljs-worker-pool.js",
    "providers/codearts/sqljs-worker.js",
    "providers/codearts/usage-rollup-calc.js",
    "providers/codearts/usage-rollup.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://example.local/codearts-bar.git"
  }
}
