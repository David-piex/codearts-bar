{
  "name": "codearts-bar-status",
  "displayName": "\u7801\u9053 \u00b7 \u4f7f\u7528\u5206\u6790",
  "description": "\u5728 VS Code / CodeArts Agent \u4e2d\u53ef\u89c6\u5316\u672c\u5730 token \u7528\u91cf\u3001\u8d8b\u52bf\u3001\u6a21\u578b\u3001\u6570\u636e\u6e90\u4e0e\u6700\u8fd1\u4f1a\u8bdd\u3002",
  "version": "1.16.34",
  "publisher": "local-codearts",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeartsBar.refresh",
    "onCommand:codeartsBar.showDetails",
    "onView:codeartsBar.overview",
    "onCommand:codeartsBar.openDashboard",
    "onCommand:codeartsBar.openOverview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeartsBar.refresh",
        "title": "\u7801\u9053\uff1a\u5237\u65b0\u4f7f\u7528\u6570\u636e",
        "icon": "$(refresh)"
      },
      {
        "command": "codeartsBar.showDetails",
        "title": "\u7801\u9053\uff1a\u6253\u5f00\u5b8c\u6574\u4f7f\u7528\u5206\u6790",
        "icon": "$(graph)"
      },
      {
        "command": "codeartsBar.openDataFolder",
        "title": "\u7801\u9053\uff1a\u6253\u5f00\u672c\u5730\u6570\u636e\u76ee\u5f55",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codeartsBar.openDashboard",
        "title": "\u7801\u9053\uff1a\u6253\u5f00\u5b8c\u6574\u4f7f\u7528\u5206\u6790",
        "icon": "$(graph)"
      },
      {
        "command": "codeartsBar.openOverview",
        "title": "\u7801\u9053\uff1a\u6253\u5f00\u6982\u89c8\u4fa7\u8fb9\u680f",
        "icon": "$(layout-sidebar-left)"
      }
    ],
    "configuration": {
      "title": "\u7801\u9053 \u00b7 \u4f7f\u7528\u5206\u6790",
      "properties": {
        "codeartsBar.dbPath": {
          "type": "string",
          "default": "",
          "description": "CodeArts opencode.db \u8def\u5f84\u3002\u4e3a\u7a7a\u65f6\u4f7f\u7528 ~/.codeartsdoer/codearts-data/opencode.db\u3002"
        },
        "codeartsBar.dailyLimit": {
          "type": "number",
          "default": 200000,
          "description": "\u72b6\u6001\u680f\u767e\u5206\u6bd4\u4f7f\u7528\u7684\u6bcf\u65e5 token \u663e\u793a\u8f6f\u4e0a\u9650\u3002"
        },
        "codeartsBar.windowHours": {
          "type": "number",
          "default": 24,
          "description": "\u6eda\u52a8\u7a97\u53e3\u7edf\u8ba1\u5c0f\u65f6\u6570\u3002"
        },
        "codeartsBar.refreshMs": {
          "type": "number",
          "default": 60000,
          "description": "\u81ea\u52a8\u5237\u65b0\u95f4\u9694\uff0c\u6beb\u79d2\u3002"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeartsBar",
          "title": "\u7801\u9053",
          "icon": "media/codearts.svg"
        }
      ]
    },
    "views": {
      "codeartsBar": [
        {
          "type": "webview",
          "id": "codeartsBar.overview",
          "name": "\u4f7f\u7528\u6982\u89c8",
          "icon": "media/codearts.svg",
          "contextualTitle": "\u7801\u9053 \u00b7 \u4f7f\u7528\u6982\u89c8"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codeartsBar.refresh",
          "when": "view == codeartsBar.overview",
          "group": "navigation@1"
        },
        {
          "command": "codeartsBar.openDashboard",
          "when": "view == codeartsBar.overview",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "codeartsBar.refresh"
        },
        {
          "command": "codeartsBar.openDashboard"
        },
        {
          "command": "codeartsBar.openOverview"
        },
        {
          "command": "codeartsBar.openDataFolder"
        }
      ]
    }
  },
  "files": [
    "extension.js",
    "codeartsData.js",
    "node_modules/sql.js/dist/sql-wasm.js",
    "node_modules/sql.js/dist/sql-wasm.wasm",
    "README.md",
    "package.json",
    "LICENSE",
    "officialStats.js",
    "authStatus.js",
    "settings.js",
    "quota.js",
    "providers/index.js",
    "health.js",
    "extension-data.js",
    "providers/codeartsLocal.js",
    "providers/codeartsOfficial.js",
    "providers/codeartsDesktop.js",
    "core/aggregator.js",
    "core/format.js",
    "core/cacheMetrics.js",
    "providers/codearts/aggregation-sql.js",
    "providers/codearts/aggregation.js",
    "providers/codearts/collect.js",
    "providers/codearts/logs.js",
    "providers/codearts/pagination.js",
    "providers/codearts/session-actions.js",
    "providers/codearts/sources.js",
    "providers/codearts/sqlite.js",
    "providers/codearts/aggregate-cache.js",
    "providers/codearts/aggregation-engine.js",
    "providers/codearts/aggregation-runtime.js",
    "providers/codearts/aggregation-sql-expressions.js",
    "providers/codearts/aggregation-workers.js",
    "providers/codearts/diagnostics.js",
    "providers/codearts/rollup-cache.js",
    "providers/codearts/sqljs-worker-pool.js",
    "providers/codearts/sqljs-worker.js",
    "providers/codearts/usage-rollup-calc.js",
    "providers/codearts/usage-rollup.js",
    "dashboard.js",
    "media/codearts.svg",
    "webview/html.js",
    "webview/model.js",
    "media/styles/tokens.css",
    "media/styles/foundation.css",
    "media/styles/components.css",
    "media/styles/responsive.css",
    "media/scripts/format.js",
    "media/scripts/chart-axis.js",
    "media/scripts/chart.js",
    "media/scripts/views.js",
    "media/scripts/dashboard.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://example.local/codearts-bar.git"
  }
}
